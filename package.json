{
  "name": "z3tz3r0.github.io",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint -D all -A react-in-jsx-scope -A jsx-filename-extension -A no-named-export -A prefer-default-export -A jsx-max-depth -A no-duplicate-imports -A no-duplicates --deny-warnings .",
    "lint:fix": "oxlint --fix .",
    "type-check": "tsc --noEmit",
    "validate": "bun run type-check && bun run lint",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "@react-email/components": "^0.0.41",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "lucide-react": "^0.488.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^3.0.2",
    "resend": "^4.5.1",
    "simple-icons": "^14.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.2.5",
    "web-vitals": "^5.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.59.0",
    "puppeteer": "^24.40.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --deny=correctness"
    ]
  }
